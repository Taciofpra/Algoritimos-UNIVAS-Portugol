programa {
  funcao inicio() {
    real n1, n2, n3, media

    escreva("-----------------------------\n")
    escreva("--Calculo de média de notas--\n")
    escreva("-----------------------------\n")

    escreva("Digite o valor da nota 1: ")
    leia(n1)

    escreva("Digite o valor da nota 2: ")
    leia(n2)

    escreva("Digite o valor da nota 3: ")
    leia(n3)

    media = (n1+n2+n3)/3

    escreva("A media final do aluno é: ", media)

  }
}
