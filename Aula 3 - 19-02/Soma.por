programa {
  funcao inicio() {
    inteiro n1, n2, soma

    escreva("----------------\n")
    escreva("--Soma simples--\n")
    escreva("----------------\n")

    escreva("Digite o Valor n1:")
    leia(n1)

    escreva("Digite o Valor n2: ")
    leia(n2)

    soma = n1+n2

    escreva("A soma de ", n1," e ", n2," é igual a: ", soma)

  }
}
